{
  "name": "in-draft",
  "version": "0.1.0",
  "description": "Personal LinkedIn post assistant: collects current news, drafts opinionated posts in your voice, lets you edit conversationally, and publishes only after a passkey assertion.",
  "license": "MIT",
  "homepage": "https://github.com/feRpicoral/in-draft#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feRpicoral/in-draft.git"
  },
  "bugs": {
    "url": "https://github.com/feRpicoral/in-draft/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dry-run": "tsx scripts/cli/index.ts dry-run",
    "indraft": "tsx scripts/cli/index.ts",
    "setup": "tsx scripts/setup.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@vercel/kv": "^3.0.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "nanoid": "^5.0.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "msw": "^2.6.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
