# InDraft secrets. Copy to .env.local for local dev; on Vercel, set these
# in the project's environment variables. Never commit a real .env.

# --- LinkedIn API (personal posting) ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- LLM (OpenRouter with BYOK) ---
# Get an OpenRouter key, then attach your own Anthropic key under BYOK.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Email (send-only via Resend) ---
RESEND_API_KEY=
NOTIFY_TO_ADDRESS=you@example.com
NOTIFY_FROM_ADDRESS=indraft@your-verified-domain.com

# --- Stock images ---
PEXELS_API_KEY=

# --- Magic links + sessions ---
# Use a long random string (>= 32 chars). Rotating invalidates outstanding links.
MAGIC_LINK_SIGNING_SECRET=

# --- WebAuthn (passkey) ---
# The relying-party ID is the bare domain (no scheme, no port). For local dev: localhost
WEBAUTHN_RP_ID=localhost

# --- Cron ---
# Long random string. Vercel injects this as Authorization: Bearer ${CRON_SECRET}
CRON_SECRET=

# --- One-time setup ---
# Long random string. Used once to enroll the first passkey via /enroll. Rotate or
# unset after enrollment.
ENROLLMENT_BOOTSTRAP_TOKEN=

# --- Vercel KV (injected automatically when you run `vercel env pull .env.local`) ---
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
# KV_URL=
